# Ecomail API
ECOMAIL_API_KEY=your_ecomail_api_key
ECOMAIL_API_URL=https://api2.ecomail.cz
ECOMAIL_LIST_ID=1

# Anabix API
ANABIX_API_USER=your_anabix_username
ANABIX_API_TOKEN=your_anabix_token
ANABIX_API_URL=https://YOUR_ACCOUNT.anabix.cz/api

# Mapping: comma-separated Anabix group IDs to assign new contacts to
ANABIX_GROUP_IDS=

# Webhook secret (optional, for validating incoming webhook requests)
WEBHOOK_SECRET=

# Google Sheets (for google-sheets-sync.php)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_SPREADSHEET_ID=1kjcecr6q7G_GSnU4ttCJyCankyGIq_6Au7zSdF2Dajw
GOOGLE_SHEET_NAME=Optimal-Marketing-odhlášeno

# Sync settings
# How many Ecomail subscribers to fetch per page (max 20)
ECOMAIL_PAGE_SIZE=20

# Google Sheets CSV URL for Campaign Monitor notes import
# Publish your Google Sheet as CSV: File > Share > Publish to web > CSV
# Or leave empty and pass a local CSV file path as argument to sync-notes.php
GOOGLE_SHEET_CSV_URL=

# Prefix for Campaign Monitor notes in Anabix (default: "Campaign Monitor Reason")
CAMPAIGN_MONITOR_NOTE_PREFIX=Campaign Monitor Reason

# Google Sheets sync (for sync-sheets.php)
# Spreadsheet ID from the Google Sheets URL
GOOGLE_SHEET_ID=1kjcecr6q7G_GSnU4ttCJyCankyGIq_6Au7zSdF2Dajw
# GID of the specific sheet tab
GOOGLE_SHEET_GID=243832774
# Column names in the Google Sheet
SHEET_COL_EMAIL=EmailAddress
SHEET_COL_DATE=Date
SHEET_COL_REASON=Reason

# Activity settings for Google Sheets sync
# idUser for activity owner (5 = Robot Karel)
ANABIX_ACTIVITY_ID_USER=5
ANABIX_ACTIVITY_TYPE=note
ANABIX_ACTIVITY_TITLE=Odhlášení z newsletteru
