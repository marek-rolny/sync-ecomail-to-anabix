# ═══════════════════════════════════════════════════════════════════════
# Anabix → Ecomail Sync Configuration
# ═══════════════════════════════════════════════════════════════════════

# ── Anabix CRM API ─────────────────────────────────────────────────────
ANABIX_USERNAME=your_anabix_username
ANABIX_TOKEN=your_anabix_token
ANABIX_API_URL=https://YOUR_ACCOUNT.anabix.cz/api

# ── Ecomail API ────────────────────────────────────────────────────────
ECOMAIL_API_KEY=your_ecomail_api_key
ECOMAIL_API_URL=https://api2.ecomailapp.cz
ECOMAIL_LIST_ID=1

# ── Sync settings ─────────────────────────────────────────────────────
# Force sync from a specific date (overrides delta). Format: YYYY-MM-DD HH:MM:SS
#SYNC_FORCE_SINCE=2025-01-01 00:00:00

# Safety overlap window for delta sync (minutes, default 60)
SYNC_LOOKBACK_MINUTES=60

# Path to sync state file
#SYNC_STATE_FILE=storage/state/last_sync.json

# ── Ecomail import options ─────────────────────────────────────────────
# Batch size for subscribe-bulk (default 500, max 1000)
ECOMAIL_BATCH_SIZE=500

# Trigger autoresponder sequences for new subscribers (default false)
ECOMAIL_TRIGGER_AUTORESPONDERS=false

# Resubscribe previously unsubscribed contacts (default false)
ECOMAIL_RESUBSCRIBE=false

# ── Anabix data enrichment ─────────────────────────────────────────────
# Fetch full contact detail (slower but more data, default false)
ANABIX_FETCH_DETAIL=false

# Fetch list memberships and use as tags in Ecomail (default true)
ANABIX_FETCH_LISTS=true

# Fetch organization data for company fields (default true)
ANABIX_FETCH_ORGS=true

# Org fetch parallelism (default 20)
ANABIX_ORG_CONCURRENCY=20

# Path to organization cache file
#ANABIX_ORG_CACHE_FILE=storage/state/org_cache.json

# ── Owner mapping (idOwner → name for projectManager custom field) ─────
ANABIX_OWNER_1=Marek Rolný
ANABIX_OWNER_2=Jan Zatloukal
ANABIX_OWNER_6=Robot Karel
ANABIX_OWNER_13=Václav Jurásek
ANABIX_OWNER_15=Pavlína Pitelová
ANABIX_OWNER_21=Dagmar Bílá
ANABIX_OWNER_24=Anna Králíčková

# ── Custom field mapping (Ecomail merge tag → Anabix custom field ID) ──
# Format: ANABIX_CF_<ecomailMergeTag>=<anabixCustomFieldId>
ANABIX_CF_prvniObchod=10

# Birthday custom field ID in Anabix (mapped to Ecomail 'birthday' field)
ANABIX_BIRTHDAY_FIELD_ID=5

# ── Activities sync (Ecomail → Anabix) ────────────────────────────────
# Anabix user ID for activity ownership (e.g. 6 = Robot Karel)
ANABIX_ACTIVITY_ID_USER=6

# ── Google Sheets → Anabix (sync-sheets.php) ──────────────────────────
# Spreadsheet ID from the Google Sheets URL
GOOGLE_SHEET_ID=your_spreadsheet_id
# GID of the specific sheet tab
GOOGLE_SHEET_GID=0
# Column names
SHEET_COL_EMAIL=EmailAddress
SHEET_COL_DATE=Date
SHEET_COL_REASON=Reason
# Activity type and title
ANABIX_ACTIVITY_TYPE=note
ANABIX_ACTIVITY_TITLE=Odhlášení z newsletteru
