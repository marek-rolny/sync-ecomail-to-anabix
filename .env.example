# Ecomail API
ECOMAIL_API_KEY=your_ecomail_api_key
ECOMAIL_API_URL=https://api2.ecomail.cz
ECOMAIL_LIST_ID=1

# Anabix API
ANABIX_API_USER=your_anabix_username
ANABIX_API_TOKEN=your_anabix_token
ANABIX_API_URL=https://YOUR_ACCOUNT.anabix.cz/api

# Mapping: comma-separated Anabix group IDs to assign new contacts to
ANABIX_GROUP_IDS=

# Webhook secret (optional, for validating incoming webhook requests)
WEBHOOK_SECRET=

# Sync settings
# How many Ecomail subscribers to fetch per page (max 20)
ECOMAIL_PAGE_SIZE=20

# WLB (Web Local Business) form sync
# API URL for WLB
WLB_API_URL=https://www.optimal-marketing.cz/wlb

# Forms to sync: comma-separated list of formId:password pairs
# Example: 72:1c8073aca683f20eb1587071e56dd3b177032a7a,85:abc123def456
WLB_FORMS=

# Anabix group IDs for contacts created from WLB forms (optional, falls back to ANABIX_GROUP_IDS)
WLB_ANABIX_GROUP_IDS=
