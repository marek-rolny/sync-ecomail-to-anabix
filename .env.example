# Ecomail API
ECOMAIL_API_KEY=your_ecomail_api_key
ECOMAIL_API_URL=https://api2.ecomail.cz
ECOMAIL_LIST_ID=1

# Anabix API
ANABIX_API_USER=your_anabix_username
ANABIX_API_TOKEN=your_anabix_token
ANABIX_API_URL=https://YOUR_ACCOUNT.anabix.cz/api

# Mapping: comma-separated Anabix group IDs to assign new contacts to
ANABIX_GROUP_IDS=

# Webhook secret (optional, for validating incoming webhook requests)
WEBHOOK_SECRET=

# Sync settings
# How many Ecomail subscribers to fetch per page (max 20)
ECOMAIL_PAGE_SIZE=20
